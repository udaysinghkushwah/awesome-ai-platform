{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@awesome-ai/sdk": ["packages/sdk/dist"],
      "@awesome-ai/shared": ["packages/shared/dist"],
      "@awesome-ai/logger": ["packages/logger/dist"],
      "@awesome-ai/database": ["packages/database/dist"]
    }
  },
  "exclude": ["node_modules", "dist", "out", ".next", "build"]
}
